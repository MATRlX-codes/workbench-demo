# --- Public demo mode (no auth, no DB — safe to deploy as a shareable link) ---
# When "true", the app skips Clerk auth and the database entirely and serves
# only client-side mock data. This is set automatically for production builds
# via .env.production, so a Vercel deploy needs no secrets at all.
# NEXT_PUBLIC_DEMO_MODE=true

# --- Dev mock mode (no real API keys needed) ---
# Set to true to run all workflows with mock data and show all connectors as connected.
MOCK_MODE=true

# --- Anthropic ---
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Clerk (auth + Organizations as tenants) ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
CLERK_WEBHOOK_SECRET=whsec_...

# --- Database (Neon recommended; any Postgres works) ---
DATABASE_URL=postgresql://user:pass@host:5432/workbench?sslmode=require

# --- Token encryption (per-tenant connector tokens) ---
# Generate with: openssl rand -hex 32   (must be 64 hex chars = 32 bytes)
TENANT_ENCRYPTION_KEY=<64-char hex string>

# --- MCP server URLs (one per supported connector) ---
MCP_QUICKBOOKS_URL=https://...
MCP_HUBSPOT_URL=https://...
MCP_GMAIL_URL=https://...
MCP_GOOGLE_CALENDAR_URL=https://...
MCP_GOOGLE_DRIVE_URL=https://...
MCP_MICROSOFT_365_URL=https://...
MCP_STRIPE_URL=https://...
MCP_PAYPAL_URL=https://...
MCP_SQUARE_URL=https://...
MCP_CANVA_URL=https://...
MCP_DOCUSIGN_URL=https://...
MCP_SLACK_URL=https://...
MCP_WEBFLOW_URL=https://...
# &Again-built MCP servers (Phase 3)
MCP_REVENUE_URL=https://...

# --- Background jobs (Phase 2) ---
INNGEST_EVENT_KEY=...
INNGEST_SIGNING_KEY=...

# --- Email (Phase 2) ---
RESEND_API_KEY=re_...
RESEND_FROM=workbench@andagain.ie

# --- Observability (optional) ---
SENTRY_DSN=...
AXIOM_TOKEN=...

# --- App URL (used as OAuth redirect_uri base) ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

## OAuth connector credentials
# QuickBooks
QB_CLIENT_ID=
QB_CLIENT_SECRET=

# Google (Gmail, Google Calendar, Google Drive share one OAuth app)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Microsoft 365
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# HubSpot
HUBSPOT_CLIENT_ID=
HUBSPOT_CLIENT_SECRET=

# Stripe Connect
STRIPE_CLIENT_ID=
STRIPE_CLIENT_SECRET=

# PayPal
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=

# Square
SQUARE_CLIENT_ID=
SQUARE_CLIENT_SECRET=

# Canva
CANVA_CLIENT_ID=
CANVA_CLIENT_SECRET=

# DocuSign
DOCUSIGN_CLIENT_ID=
DOCUSIGN_CLIENT_SECRET=

# Slack
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=

# Webflow
WEBFLOW_CLIENT_ID=
WEBFLOW_CLIENT_SECRET=
